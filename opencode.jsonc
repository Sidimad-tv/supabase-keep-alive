{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "enabled": true
    }
  },
  "rule": {
    "test": "After making any code changes, always use playwright MCP to open the local project in the browser and verify the changes work correctly before confirming the task is done.",
    "workflow": "Read package.json/README first, install deps, run lint/typecheck, then test via playwright before confirming."
  }
}